<?xml version="1.0"?>
<rdf:RDF xmlns="https://example.org/monopoly#MonopolyOntology#"
     xml:base="https://example.org/monopoly#MonopolyOntology"
     xmlns:mon="https://example.org/monopoly#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="https://example.org/monopoly#MonopolyOntology">
        <rdfs:label>Monopoly Board Game Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://example.org/monopoly#bankHolds -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#bankHolds">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Bank"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:comment>Spaces currently held by the bank.</rdfs:comment>
        <rdfs:label>bankHolds</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#belongsTo -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#belongsTo">
        <owl:inverseOf rdf:resource="https://example.org/monopoly#owns"/>
        <rdfs:domain rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:comment>Inverse of owns.</rdfs:comment>
        <rdfs:label>belongsTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#currentSpace -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#currentSpace">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:comment>The space where a player currently is located.</rdfs:comment>
        <rdfs:label>currentSpace</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#deedForProperty -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#deedForProperty">
        <rdfs:domain rdf:resource="https://example.org/monopoly#TitleDeed"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:comment>Relates a title deed to the space it represents.</rdfs:comment>
        <rdfs:label>deedForProperty</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#drawsCard -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#drawsCard">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Card"/>
        <rdfs:label>drawsCard</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#forSpace -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#forSpace">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Transaction"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:label>forSpace</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#hasBuilding -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#hasBuilding">
        <rdfs:domain rdf:resource="https://example.org/monopoly#PropertySpace"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Building"/>
        <rdfs:comment>Buildings placed on a buildable property.</rdfs:comment>
        <rdfs:label>hasBuilding</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#hasMonopoly -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#hasMonopoly">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#PropertyGroup"/>
        <rdfs:comment>Represents that a player controls a complete set.</rdfs:comment>
        <rdfs:label>hasMonopoly</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#hasPayee -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#hasPayee">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Transaction"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#GameEntity"/>
        <rdfs:label>hasPayee</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#hasPayer -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#hasPayer">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Transaction"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#GameEntity"/>
        <rdfs:label>hasPayer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#hasSpace -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#hasSpace">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Board"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:comment>Links the Monopoly board to the spaces on the board.</rdfs:comment>
        <rdfs:label>hasSpace</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#hasTitleDeed -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#hasTitleDeed">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#TitleDeed"/>
        <rdfs:comment>A title deed currently held by a player.</rdfs:comment>
        <rdfs:label>hasTitleDeed</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#memberOfGroup -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#memberOfGroup">
        <rdfs:domain rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#PropertyGroup"/>
        <rdfs:comment>Relates a property, railroad, or utility to its set or color group.</rdfs:comment>
        <rdfs:label>memberOfGroup</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#nextSpace -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#nextSpace">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:comment>Circular ordering of the board spaces.</rdfs:comment>
        <rdfs:label>nextSpace</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#nextTurn -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#nextTurn">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Turn"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Turn"/>
        <rdfs:label>nextTurn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#owns -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#owns">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:comment>Relates a player to a property, railroad, or utility the player owns.</rdfs:comment>
        <rdfs:label>owns</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#sendsToJail -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#sendsToJail">
        <rdfs:domain rdf:resource="https://example.org/monopoly#GoToJailSpace"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#JailSpace"/>
        <rdfs:comment>Go To Jail sends the player to Jail.</rdfs:comment>
        <rdfs:label>sendsToJail</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#triggeredByCard -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#triggeredByCard">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Transaction"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Card"/>
        <rdfs:label>triggeredByCard</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/monopoly#turnOf -->

    <owl:ObjectProperty rdf:about="https://example.org/monopoly#turnOf">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Turn"/>
        <rdfs:range rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:label>turnOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://example.org/monopoly#amount -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#amount">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>amount</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#baseRent -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#baseRent">
        <rdfs:domain rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>baseRent</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#cashBalance -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#cashBalance">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>cashBalance</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#groupSize -->

