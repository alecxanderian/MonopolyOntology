        <mon:hotelCost rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">150</mon:hotelCost>
        <mon:houseCost rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">150</mon:houseCost>
