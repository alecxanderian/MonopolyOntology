        <rdfs:domain rdf:resource="https://example.org/monopoly#PropertyGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>groupSize</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#hotelCost -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#hotelCost">
        <rdfs:domain rdf:resource="https://example.org/monopoly#PropertySpace"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>hotelCost</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#houseCost -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#houseCost">
        <rdfs:domain rdf:resource="https://example.org/monopoly#PropertySpace"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>houseCost</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#isBankrupt -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#isBankrupt">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isBankrupt</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#isBuildable -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#isBuildable">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isBuildable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#isInJail -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#isInJail">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isInJail</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#isMortgaged -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#isMortgaged">
        <rdfs:domain rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isMortgaged</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#isPurchasable -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#isPurchasable">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isPurchasable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#mortgageValue -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#mortgageValue">
        <rdfs:domain rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>mortgageValue</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#ownedCount -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#ownedCount">
        <rdfs:domain rdf:resource="https://example.org/monopoly#PropertyGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>ownedCount</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#purchasePrice -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#purchasePrice">
        <rdfs:domain rdf:resource="https://example.org/monopoly#OwnableSpace"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>purchasePrice</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/monopoly#spaceNumber -->

    <owl:DatatypeProperty rdf:about="https://example.org/monopoly#spaceNumber">
        <rdfs:domain rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>spaceNumber</rdfs:label>
