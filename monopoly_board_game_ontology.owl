    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://example.org/monopoly#AuctionSale -->

    <owl:Class rdf:about="https://example.org/monopoly#AuctionSale">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#Transaction"/>
        <rdfs:label>AuctionSale</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/monopoly#Bank -->

    <owl:Class rdf:about="https://example.org/monopoly#Bank">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#GameEntity"/>
        <rdfs:label>Bank</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/monopoly#BankerPlayer -->

    <owl:Class rdf:about="https://example.org/monopoly#BankerPlayer">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#Player"/>
        <rdfs:label>Banker-Role Player</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/monopoly#Board -->

    <owl:Class rdf:about="https://example.org/monopoly#Board">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#GameEntity"/>
        <rdfs:label>Board</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/monopoly#Building -->

    <owl:Class rdf:about="https://example.org/monopoly#Building">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#GameEntity"/>
        <rdfs:label>Building</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/monopoly#Card -->

    <owl:Class rdf:about="https://example.org/monopoly#Card">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#GameEntity"/>
        <rdfs:label>Card</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/monopoly#ChanceCard -->

    <owl:Class rdf:about="https://example.org/monopoly#ChanceCard">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#Card"/>
        <rdfs:label>ChanceCard</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/monopoly#ChanceSpace -->

    <owl:Class rdf:about="https://example.org/monopoly#ChanceSpace">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#Space"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/monopoly#isBuildable"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/monopoly#isPurchasable"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>ChanceSpace</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/monopoly#ColorGroup -->

    <owl:Class rdf:about="https://example.org/monopoly#ColorGroup">
        <rdfs:subClassOf rdf:resource="https://example.org/monopoly#PropertyGroup"/>
        <rdfs:label>ColorGroup</rdfs:label>
    </owl:Class>
    


