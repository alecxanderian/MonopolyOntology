        <mon:isMortgaged rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</mon:isMortgaged>
        <mon:isPurchasable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</mon:isPurchasable>
        <mon:mortgageValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">130</mon:mortgageValue>
